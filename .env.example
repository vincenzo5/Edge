# Local Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://tvai:tvai@localhost:5432/tvai

# Required for signed placeholder auth when persistence is enabled
EDGE_AUTH_SECRET=replace-with-a-long-random-secret

# Optional dev user email for the placeholder auth boundary
EDGE_DEV_USER_EMAIL=dev@localhost

# Cursor SDK — local docs auto-update hook (optional; npm run hooks:install)
CURSOR_API_KEY=
# Optional model override for docs automation (default: auto)
CURSOR_DOCS_MODEL=

# Market data providers (optional — Yahoo works without keys for dev)
FRED_API_KEY=
FMP_API_KEY=
MASSIVE_API_KEY=
POLYGON_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_UNIVERSE_LOOKBACK_DAYS=252
MASSIVE_UNIVERSE_MAX_WARM_CALLS=252
TRADIER_ACCESS_TOKEN=
TRADIER_API_URL=https://sandbox.tradier.com/v1
SEC_USER_AGENT=EdgeChart/1.0 (contact@example.com)

# IBKR Client Portal Gateway (read-only market data; login via Gateway browser UI)
# Default: https://localhost:5001/v1/api — on macOS, port 5000 is often AirPlay; use 5001 in Gateway conf.yaml.
IBKR_ENABLED=false
IBKR_BASE_URL=https://localhost:5001/v1/api
IBKR_SSL_VERIFY=false
IBKR_READ_ONLY=true
IBKR_COMPETE_SESSION=false

# IB Gateway / TWS API sidecar (read-only market data via local Python sidecar)
# Paper Gateway default port is 4002; live Gateway uses 4001.
TWS_ENABLED=false
TWS_HOST=127.0.0.1
TWS_PORT=4002
TWS_CLIENT_ID=77
TWS_READONLY=true
TWS_SIDECAR_URL=http://127.0.0.1:8765
TWS_SIDECAR_PORT=8765
# Who manages the sidecar process: local (Next spawns/kills when TWS_ENABLED) or external (run npm run tws:sidecar manually)
TWS_MANAGED=local
TWS_SIDECAR_TIMEOUT_MS=15000
TWS_CANDLES_TIMEOUT_MS=3000
TWS_QUOTES_TIMEOUT_MS=3000
TWS_OPTIONS_TIMEOUT_MS=15000

# IB account tracking (read-only by default; positions/PnL via TWS sidecar)
# Optional — defaults to first managed account from IB Gateway
TWS_ACCOUNT_ID=

# Optional: WebGL2 candle renderer for main-pane OHLC (falls back to Canvas when unavailable)
# NEXT_PUBLIC_WEBGL_CANDLES=1

# Optional: WebGL2 renderer for declarative indicator line/histogram series
# NEXT_PUBLIC_WEBGL_INDICATORS=1

# Optional: server-proxied SSE for live candle/quote updates (default: client polling)
# NEXT_PUBLIC_STREAM_TRANSPORT=server-proxied

# Watchlist live quote stream via /api/stream/quotes (default: on when EventSource available)
# NEXT_PUBLIC_WATCHLIST_STREAM=1

# Market data latency telemetry in dev (panel + console export)
# NEXT_PUBLIC_MARKET_DATA_TELEMETRY=1

# Include server phase metadata in API responses and perf baselines
# MARKET_DATA_PERF=1
