{
  "name": "tv-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "setup": "npm ci",
    "check": "npm run lint:instructions && npm run check:packages && npm test -- --run && npm run build",
    "check:packages": "npm run lint:package-boundaries && npm run typecheck:packages && npm run check:examples",
    "check:examples": "npm run build:packages && npm run check -w @edge/example-chart-core-basic && npm run check -w @edge/example-chart-react-basic && npm run check -w @edge/example-chart-plugins-basic && npm run check -w @edge/example-ai-tools-chart-basic && npm run check -w @edge/example-chart-data-source-basic && npm run check -w @edge/example-chart-perf-harness",
    "check:startup": "npm run lint:instructions && npm test -- --run src/test/startup.test.ts src/app/components/chartContextMenu.test.ts src/app/components/chartCopyMenu.test.ts",
    "lint:package-boundaries": "npx tsx scripts/validate-package-boundaries.mts",
    "typecheck:packages": "npm run typecheck -w @edge/chart-core && npm run typecheck -w @edge/chart-react && npm run typecheck -w @edge/ai-tools-core && npm run typecheck -w @edge/ai-tools-chart",
    "build:packages": "npm run build -w @edge/chart-core && npm run build -w @edge/chart-react && npm run build -w @edge/ai-tools-core && npm run build -w @edge/ai-tools-chart",
    "build:example": "npm run build:packages && npm run check:examples",
    "dev": "bash scripts/dev-with-db.sh",
    "dev:lite": "TWS_ENABLED=true next dev -p 3003",
    "dev:with-db": "npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:instructions": "npx tsx scripts/validate-agent-instructions.mts",
    "test": "vitest",
    "mcp:edge": "npx tsx scripts/edge-mcp-server.mts",
    "db:up": "docker compose up -d postgres",
    "db:wait": "npx tsx scripts/wait-for-postgres.mts",
    "db:down": "docker compose down",
    "db:migrate": "npx tsx scripts/db-migrate.mts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "ib:gateway:up": "docker compose --project-directory services/ib-gateway -f services/ib-gateway/docker-compose.yml up -d",
    "ib:gateway:down": "docker compose --project-directory services/ib-gateway -f services/ib-gateway/docker-compose.yml down",
    "ibkr:setup": "bash scripts/ibkr-setup-gateway.sh",
    "ibkr:gateway": "bash scripts/ibkr-gateway.sh",
    "ibkr:probe": "npx tsx scripts/ibkr-probe.mts",
    "ibkr:options-probe": "npx tsx scripts/ibkr-options-probe.mts",
    "tws:sidecar-setup": "bash scripts/tws-sidecar-setup.sh",
    "tws:sidecar": "bash scripts/tws-sidecar.sh",
    "tws:sidecar:test": "cd services/tws-sidecar && ../../.tools/tws-sidecar-venv/bin/python -m unittest test_main -v",
    "tws:probe": "npx tsx scripts/tws-probe.mts",
    "tws:options-probe": "npx tsx scripts/tws-options-probe.mts",
    "fmp:gap-probe": "npx tsx scripts/fmp-gap-probe.mts",
    "events:coverage-probe": "npx tsx scripts/events-coverage-probe.mts",
    "perf:chart": "npx tsx scripts/run-chart-perf.mts",
    "perf:market-data": "npx tsx scripts/run-market-data-perf.mts",
    "docs:auto-update": "npx tsx scripts/update-docs-for-diff.mts",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.22",
    "@edge/ai-tools-chart": "*",
    "@edge/ai-tools-core": "*",
    "@edge/chart-core": "*",
    "@edge/chart-react": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "drizzle-orm": "^0.45.2",
    "html-to-image": "^1.11.13",
    "next": "^16.2.9",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "ws": "^8.21.0",
    "yahoo-finance2": "^3.15.3",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.9",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^7.2.4",
    "vitest": "^4.1.9"
  }
}
