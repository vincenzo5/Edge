{
  "name": "@edge/chart-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js"
    },
    "./format": {
      "types": "./dist/format.d.ts",
      "import": "./dist/format.js"
    },
    "./indicators": {
      "types": "./dist/indicators/index.d.ts",
      "import": "./dist/indicators/index.js"
    },
    "./drawings": {
      "types": "./dist/drawings/index.d.ts",
      "import": "./dist/drawings/index.js"
    },
    "./plugin-api": {
      "types": "./dist/plugin-api.d.ts",
      "import": "./dist/plugin-api.js"
    },
    "./series": {
      "types": "./dist/series.d.ts",
      "import": "./dist/series.js"
    },
    "./panes": {
      "types": "./dist/panes.d.ts",
      "import": "./dist/panes.js"
    },
    "./data-source": {
      "types": "./dist/dataSource.d.ts",
      "import": "./dist/dataSource.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./*/*": {
      "types": "./dist/*/*.d.ts",
      "import": "./dist/*/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
