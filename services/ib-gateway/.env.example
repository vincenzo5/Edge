# Copy to services/ib-gateway/.env — never commit .env (gitignored).
# Required for TRADING_MODE=both: live + paper credentials.

TRADING_MODE=both
EXISTING_SESSION_DETECTED_ACTION=primary
READ_ONLY_API=no

# Live account
TWS_USERID=your-ib-username
TWS_PASSWORD=your-ib-password

# Paper account (required when TRADING_MODE=both)
TWS_USERID_PAPER=your-ib-username
TWS_PASSWORD_PAPER=your-ib-paper-password

# VNC for 2FA / login UI at localhost:5900
VNC_SERVER_PASSWORD=replace-with-a-local-vnc-password
