# Copy to services/ib-gateway/.env — never commit .env (gitignored).
# Separate live + paper containers — no shared-display 2FA race.

EXISTING_SESSION_DETECTED_ACTION=primary
READ_ONLY_API=no
TWS_ACCEPT_INCOMING=accept
BYPASS_WARNING=yes

# 2FA: restart + relogin until IBKR Mobile approves; persisted settings skip repeat 2FA.
TWOFA_TIMEOUT_ACTION=restart
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
TWOFA_EXIT_INTERVAL=300
# TWOFA_DEVICE=IBKR Mobile

# Live account (ib-gateway-live → host port 4001)
TWS_USERID=your-ib-username
TWS_PASSWORD=your-ib-password

# Paper account (ib-gateway-paper → host port 4002)
TWS_USERID_PAPER=your-ib-username
TWS_PASSWORD_PAPER=your-ib-paper-password

# VNC optional per container (live:5900 conflicts with macOS Screen Sharing — omit if taken)
VNC_SERVER_PASSWORD=replace-with-a-local-vnc-password
